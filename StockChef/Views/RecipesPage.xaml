<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StockChef.Views.RecipesPage"
    Title="Recepti"
    BackgroundColor="#F8EDED">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <VerticalStackLayout
            Grid.Row="0"
            Spacing="5">

            <Label
                Text="Recepti"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#5F0F12" />

            <Label
                Text="Pronađite inspiraciju za kuhanje."
                FontSize="15"
                TextColor="#64748B" />

        </VerticalStackLayout>

        <CollectionView
            Grid.Row="1"
            Margin="0,15,0,0"
            ItemsSource="{Binding Recipes}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedRecipe}">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                        BackgroundColor="White"
                        Padding="15"
                        Margin="0,0,0,12"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout>

                            <Image
                                Source="{Binding ImageUrl}"
                                HeightRequest="180"
                                WidthRequest="300"
                                HorizontalOptions="Center"
                                Aspect="AspectFit" />

                            <Label
                                Text="{Binding Name}"
                                FontSize="20"
                                FontAttributes="Bold"
                                Margin="0,10,0,0"
                                TextColor="#1E293B" />

                            <Label
                                Text="{Binding Category}"
                                FontSize="14"
                                TextColor="#8B1E24" />

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>