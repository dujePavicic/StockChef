<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StockChef.Views.IngredientsPage"
    Title="Namirnice"
    BackgroundColor="#F8EDED">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <Label
                Text="Namirnice"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#5F0F12" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="20">

            <Button
                Text="Sve"
                Command="{Binding ShowAllCommand}"
                BackgroundColor="#8B1E24"
                TextColor="White"
                CornerRadius="12" />

            <Button
                Text="Frižider"
                Command="{Binding FilterFridgeCommand}"
                BackgroundColor="#B23A48"
                TextColor="White"
                CornerRadius="12" />

            <Button
                Text="Ostava"
                Command="{Binding FilterPantryCommand}"
                BackgroundColor="#B23A48"
                TextColor="White"
                CornerRadius="12" />

            <Button
                Text="+"
                Command="{Binding OpenAddIngredientCommand}"
                BackgroundColor="#5F0F12"
                TextColor="White"
                CornerRadius="12"
                WidthRequest="55" />

        </HorizontalStackLayout>

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Ingredients}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        BackgroundColor="White"
                        Padding="18"
                        Margin="0,0,0,12"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">

                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="{Binding Name}"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#1E293B" />

                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="{Binding Category}"
                                FontSize="14"
                                TextColor="#64748B" />

                            <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="{Binding Location}"
                                FontSize="14"
                                TextColor="#8B1E24" />

                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding Quantity}"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#8B1E24" />

                            <Label
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="{Binding ExpirationDate, StringFormat='Rok: {0:dd.MM.yyyy}'}"
                                FontSize="14"
                                TextColor="#B23A48" />
                           
                            <Button
                                Grid.Row="1"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Text="Izbriši"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteIngredientCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="#B23A48"
                                TextColor="White"
                                CornerRadius="10"
                                FontSize="12" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>