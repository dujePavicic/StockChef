<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StockChef.Views.ShoppingListPage"
    Title="Shopping lista"
    BackgroundColor="#F8EDED">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <Label
                Text="Shopping lista"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#5F0F12" />

            <Label
                Text="Popis namirnica"
                FontSize="15"
                TextColor="#64748B" />
        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Text="+ Dodaj namirnicu"
            Command="{Binding OpenAddShoppingItemCommand}"
            BackgroundColor="#8B1E24"
            TextColor="White"
            CornerRadius="15"
            HeightRequest="55" />

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding ShoppingItems}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        BackgroundColor="White"
                        Padding="18"
                        Margin="0,0,0,12"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{Binding IsBought}" />

                            <Label
                                Grid.Column="1"
                                Text="{Binding Name}"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#1E293B"
                                VerticalOptions="Center" />

                            <Button
                                Grid.Column="2"
                                Text="Delete"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteShoppingItemCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="#B23A48"
                                TextColor="White"
                                CornerRadius="10"
                                FontSize="12" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>